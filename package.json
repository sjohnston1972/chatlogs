{
  "name": "chatlogs-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Private read-only admin dashboard for chatbot transcripts stored in Cloudflare D1.",
  "type": "module",
  "scripts": {
    "build": "vite build --config web/vite.config.ts",
    "dev": "wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "deploy": "vite build --config web/vite.config.ts && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
